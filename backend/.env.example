# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Postgres.app on Mac runs on port 5433 by default (not 5432)
DB_NAME=vunoh
DB_USER=vunoh_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5433

# ── Redis (Celery broker + result backend) ─────────────────────────────────────
# Use DB 1 to avoid collision with other local Redis projects
REDIS_URL=redis://localhost:6379/1

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary: Groq (Llama 3.3 70B) — get key at console.groq.com
GROQ_API_KEY=your-groq-api-key

# Fallback: Google Gemini 2.0 Flash — get key at aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# ── Twilio (WhatsApp message sending) ─────────────────────────────────────────
# Get credentials at console.twilio.com
# Sandbox WhatsApp number: +14155238886 (Twilio sandbox)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password)
# Enable at: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
